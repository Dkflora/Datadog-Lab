#!/bin/bash
set -euxo pipefail
exec > >(tee /var/log/user-data.log | logger -t user-data -s 2>/dev/console) 2>&1

export DEBIAN_FRONTEND=noninteractive
apt-get update
apt-get install -y docker.io docker-compose curl git jq stress
systemctl enable docker
systemctl start docker
usermod -aG docker ubuntu || true
mkdir -p /opt/datadog-lab1/api
cd /opt/datadog-lab1

cat > /opt/datadog-lab1/api/app.py <<'PYEOF'
from flask import Flask, jsonify
import time
import random
import logging
from ddtrace import patch_all

patch_all()
app = Flask(__name__)
logging.basicConfig(level=logging.INFO)

@app.route("/")
def home():
    app.logger.info("home endpoint called")
    return jsonify({"message": "lab1 api running"})

@app.route("/slow")
def slow():
    delay = round(random.uniform(1.5, 4.5), 2)
    app.logger.info("slow endpoint called with %.2fs delay", delay)
    time.sleep(delay)
    return jsonify({"message": "slow response", "delay": delay})

@app.route("/error")
def error():
    app.logger.error("intentional application error")
    raise Exception("intentional error for Datadog lab1")

@app.route("/db")
def db():
    latency = round(random.uniform(0.2, 1.2), 2)
    app.logger.info("simulated db call with %.2fs latency", latency)
    time.sleep(latency)
    return jsonify({"message": "fake db query complete", "latency": latency})

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
PYEOF

cat > /opt/datadog-lab1/api/Dockerfile <<'DOCKEREOF'
FROM python:3.11-slim
WORKDIR /app
COPY app.py /app/app.py
RUN pip install --no-cache-dir flask ddtrace gunicorn
ENV DD_SERVICE=lab1-api
ENV DD_ENV=lab1
ENV DD_VERSION=1.0.0
CMD ["ddtrace-run", "gunicorn", "-w", "2", "-b", "0.0.0.0:5000", "app:app"]
DOCKEREOF

cat > /opt/datadog-lab1/docker-compose.yml <<'YAMLEOF'
version: "3.8"
services:
  datadog-agent:
    image: gcr.io/datadoghq/agent:7
    container_name: datadog-agent
    environment:
      DD_API_KEY: "${datadog_api_key}"
      DD_SITE: "us5.datadoghq.com"
      DD_HOSTNAME: "dev1.utrains.org"
      DD_PROCESS_AGENT_ENABLED: "true"
      DD_SYSTEM_PROBE_ENABLED: "true"
      DD_SYSTEM_PROBE_NETWORK_ENABLED: "true"
      DD_APM_ENABLED: "true"
      DD_LOGS_ENABLED: "true"
      DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL: "true"
      DD_DOGSTATSD_NON_LOCAL_TRAFFIC: "true"
    ports:
      - "127.0.0.1:8126:8126"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - /proc:/host/proc:ro
      - /sys/fs/cgroup:/host/sys/fs/cgroup:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    restart: unless-stopped

  api:
    build: ./api
    container_name: lab1-api
    environment:
      DD_AGENT_HOST: "datadog-agent"
      DD_TRACE_AGENT_PORT: "8126"
      DD_SERVICE: "lab1-api"
      DD_ENV: "lab1"
      DD_VERSION: "1.0.0"
      DD_LOGS_INJECTION: "true"
      PYTHONUNBUFFERED: "1"
    ports:
      - "5000:5000"
    depends_on:
      - datadog-agent
    restart: unless-stopped

  loadgen:
    image: curlimages/curl:8.8.0
    container_name: lab1-loadgen
    command: >
      sh -c 'while true; do
      curl -s http://api:5000/ > /dev/null || true;
      curl -s http://api:5000/db > /dev/null || true;
      if [ $$(($$RANDOM % 4)) -eq 0 ]; then curl -s http://api:5000/slow > /dev/null || true; fi;
      if [ $$(($$RANDOM % 10)) -eq 0 ]; then curl -s http://api:5000/error > /dev/null || true; fi;
      sleep 1;
      done'
    depends_on:
      - api
    restart: unless-stopped
YAMLEOF

cd /opt/datadog-lab1
docker-compose up -d --build
